@using AParCarWeb.Templates.Email.ViewModels
@model ConfirmEmailViewModel

<div style="font-family: Arial; background:#f4f6f8; padding:20px;">
    <div style="max-width:600px; margin:auto; background:#fff; padding:25px; border-radius:10px; border:1px solid #ddd;">

        <h2 style="text-align:center;">Confirmar cuenta</h2>

        <div style="text-align:center; margin:20px;">
            <svg width="60" height="60" fill="#0d6efd" viewBox="0 0 16 16">
                <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1l-8 5L0 5V4z" />
            </svg>
        </div>

        <p>Hola <strong>@(Model?.UserName ?? "Usuario")</strong>,</p>

        <p>
            Gracias por registrarte en AParCar. Confirma tu cuenta para comenzar a usar el sistema.
        </p>

        <div style="text-align:center; margin:25px 0;">
            <a href="@Model?.CallbackUrl"
                   style="background:#0d6efd; color:white; padding:12px 20px; text-decoration:none; border-radius:5px;">
                Confirmar cuenta
            </a>
        </div>

        <p style="font-size:12px; color:#777;">
            Si no creaste esta cuenta, ignora este mensaje.
        </p>

    </div>
</div>