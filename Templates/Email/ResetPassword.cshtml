@using AParCarWeb.Templates.Email.ViewModels
@model ResetPasswordViewModel

<div style="font-family: Arial; background:#f4f6f8; padding:20px;">
    <div style="max-width:600px; margin:auto; background:#fff; padding:25px; border-radius:10px; border:1px solid #ddd;">

        <div style="text-align:center;">
            <h2 style="margin-bottom:5px;">Restablecer contraseña</h2>
        </div>

        <div style="text-align:center; margin:20px;">
            <svg width="60" height="60" fill="#dc3545" viewBox="0 0 16 16">
                <path d="M8 0a4 4 0 0 0-4 4v2H3a1 1 0 0 0-1 1v7h12V7a1 1 0 0 0-1-1h-1V4a4 4 0 0 0-4-4z" />
            </svg>
        </div>

        <p>
            Recibimos una solicitud para restablecer tu contraseña.
        </p>

        <div style="text-align:center; margin:25px 0;">
            <a href="@Model.CallbackUrl"
                   style="background:#dc3545; color:white; padding:12px 20px; text-decoration:none; border-radius:5px;">
                Restablecer contraseña
            </a>
        </div>

        <p style="font-size:12px; color:#777;">
            Si no solicitaste este cambio, puedes ignorar este correo.
        </p>

        <hr />

        <small style="color:#777;">
            AParCar – Sistema de parqueo inteligente
        </small>
    </div>
</div>