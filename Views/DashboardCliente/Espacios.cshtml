@model IEnumerable<AParCarWeb.Models.Espacio>

@{
    ViewData["Title"] = "Espacios Disponibles";

    // Agrupamos los espacios por zona
    var espaciosPorZona = Model.GroupBy(e => e.Zona);
}

<div style="height:30px;"></div>

<div class="d-flex align-items-center mb-3">
    <a asp-controller="DashboardCliente"
       asp-action="Index"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Volver
    </a>
</div>

<h3 class="mb-3">
    <i class="bi bi-grid-3x3-gap"></i> Espacios disponibles
</h3>

<p class="text-muted">
    Seleccione un espacio para continuar con la reserva.
</p>

@foreach (var grupo in espaciosPorZona)
{
    var zona = grupo.Key;
    var nombreZona = zona!.Nombre!.Replace(" ", "-").ToUpper(); // Ej: "A-01"
    var rutaImagenZona = $"~/img/parking/{nombreZona}.jpg";
    var rutaImagenDefault = Url.Content("~/img/parking/espacio-default.jpg");

    <div class="zona mb-5">
        <!-- Banner de la zona -->
        <div class="d-flex align-items-center mb-3">
            <img src="@Url.Content(rutaImagenZona)"
                 alt="Zona @zona.Nombre"
                 class="me-3 rounded"
                 style="width: 60px; height: 60px; object-fit: cover;"
                 onerror="this.onerror=null;this.src='@rutaImagenDefault';" />

            <div>
                <h4 class="mb-1">@zona.Nombre</h4>
                <p class="text-muted mb-0">@zona.Descripcion</p>
            </div>
        </div>

        <!-- Espacios de esta zona -->
        <div class="row">
            @foreach (var espacio in grupo)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 border-success shadow-sm">

                        <img src="@Url.Content(rutaImagenZona)"
                             class="card-img-top"
                             alt="Espacio de parqueo"
                             onerror="this.onerror=null;this.src='@rutaImagenDefault';" />

                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-square"></i> Espacio @espacio.Codigo
                            </h5>

                            <p class="card-text mb-1">
                                <i class="bi bi-geo-alt"></i>
                                Zona: <strong>@zona.Nombre</strong>
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-0">
                            <a asp-action="Reservar"
                               asp-route-espacioId="@espacio.EspacioId"
                               class="btn btn-outline-success w-100">
                                <i class="bi bi-check-circle"></i> Reservar
                            </a>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
}