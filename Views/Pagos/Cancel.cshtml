@{
    ViewData["Title"] = "Pago Cancelado";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 text-center" style="max-width: 400px;">
        <div class="card-body">
            <!-- Icono de error -->
            <div class="mb-3">
                <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
            </div>

            <h2 class="card-title mb-3 text-danger">Pago Cancelado</h2>
            <p class="card-text mb-2">No se ha completado el pago.</p>
            <p class="card-text mb-4">Puedes intentar nuevamente si lo deseas.</p>

            <a href="@Url.Action("Index", "Home")" class="btn btn-danger btn-lg w-100">
                <i class="bi bi-house-door-fill me-2"></i> Volver al inicio
            </a>
        </div>
    </div>
</div>

<!-- Animación sutil -->
<style>
    .card {
        transform: scale(0);
        animation: popin 0.5s forwards;
    }

    @@keyframes popin {
        to {
            transform: scale(1);
        }
    }
</style>