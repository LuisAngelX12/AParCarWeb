@{
    ViewData["Title"] = "Pago Exitoso";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 text-center" style="max-width: 400px;">
        <div class="card-body">
            <!-- Icono de éxito -->
            <div class="mb-3">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            </div>

            <h2 class="card-title mb-3">¡Pago Completado!</h2>
            <p class="card-text mb-2">Tu pago se ha procesado correctamente a través de <strong>PayPal</strong>.</p>
            <p class="card-text mb-4">Gracias por tu compra.</p>

            <a href="@Url.Action("Index", "Home")" class="btn btn-success btn-lg w-100">
                <i class="bi bi-house-door-fill me-2"></i> Volver al inicio
            </a>
        </div>
    </div>
</div>

<!-- Opcional: agregar un poco de animación -->
<style>
    .card {
        transform: scale(0);
        animation: popin 0.5s forwards;
    }

    @@keyframes popin {
        to {
            transform: scale(1);
        }
    }
</style>