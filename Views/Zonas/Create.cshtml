@model AParCarWeb.Models.Zona

@{
    ViewData["Title"] = "Crear Zona";
}

<div style="height:30px;"></div>

<div class="container mt-4">

    <h2 class="mb-4">@ViewData["Title"]</h2>

    <form asp-action="Create" method="post" class="card shadow-lg p-4 rounded-4">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <!-- NOMBRE -->
        <div class="mb-3">
            <label asp-for="Nombre" class="form-label fw-semibold"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <!-- DESCRIPCION -->
        <div class="mb-4">
            <label asp-for="Descripcion" class="form-label fw-semibold"></label>
            <textarea asp-for="Descripcion" class="form-control"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                Cancelar
            </a>
            <button type="submit" class="btn btn-primary">
                Crear zona
            </button>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}