@model AParCarWeb.Models.ViewModels.Vmod2.VehiculoVM

@{
    ViewData["Title"] = "Editar vehículo";
}

<h2 class="mb-4 mt-4">Editar vehículo</h2>

<form asp-action="Edit" method="post" class="card shadow-lg p-4 rounded-4">

    <input type="hidden" asp-for="VehiculoId" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <!-- PLACA -->
    <div class="mb-3">
        <label asp-for="Placa" class="form-label fw-semibold">
            Placa (Costa Rica)
        </label>

        <input asp-for="Placa"
               id="placaInput"
               class="form-control text-uppercase"
               placeholder="ABC-123 o 123456"
               maxlength="7" />

        <small id="placaHelp" class="text-muted">
            Puede ingresar placas antiguas (123456) o nuevas (ABC-123)
        </small>

        <span asp-validation-for="Placa" class="text-danger"></span>
    </div>

    <!-- MARCA -->
    <div class="mb-3">
        <label asp-for="Marca" class="form-label fw-semibold"></label>

        <input asp-for="Marca"
               class="form-control"
               placeholder="Ej: Toyota, Hyundai, Nissan" />

        <span asp-validation-for="Marca" class="text-danger"></span>
    </div>

    <!-- MODELO -->
    <div class="mb-3">
        <label asp-for="Modelo" class="form-label fw-semibold"></label>

        <input asp-for="Modelo"
               class="form-control"
               placeholder="Ej: Corolla, Tucson, Versa" />

        <span asp-validation-for="Modelo" class="text-danger"></span>
    </div>

    <!-- COLOR -->
    <div class="mb-4">
        <label asp-for="Color" class="form-label fw-semibold">
            Color del vehículo
        </label>

        <div class="d-flex align-items-center gap-3">

            <!-- selector -->
            <input type="color"
                   id="colorPicker"
                   class="form-control form-control-color"
                   title="Seleccione el color" />

            <!-- input ligado al modelo -->
            <input asp-for="Color"
                   id="colorHex"
                   class="form-control"
                   readonly />

            <!-- preview -->
            <div id="colorPreview"
                 class="border rounded"
                 style="width:100px;height:80px;">
            </div>

        </div>

        <span asp-validation-for="Color" class="text-danger"></span>
    </div>

    <!-- CLIENTES -->
    <div class="mb-4">

        <label class="form-label fw-semibold">
            Clientes asociados
        </label>

        <select asp-for="ClientesSeleccionados"
                asp-items="ViewBag.ClientesList"
                class="form-select"
                multiple
                size="6">
        </select>

        <small class="text-muted">
            Puede seleccionar múltiples clientes.
        </small>

    </div>

    <!-- BOTONES -->
    <div class="d-flex justify-content-between mt-4">

        <a href="@Url.Action("Index")"
           class="btn btn-outline-secondary px-4">
            Cancelar
        </a>

        <button type="submit"
                class="btn btn-primary px-4">
            Actualizar vehículo
        </button>

    </div>

</form>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        const placaInput = document.getElementById("placaInput");
        const placaHelp = document.getElementById("placaHelp");

        placaInput.addEventListener("input", () => {

            let raw = placaInput.value.toUpperCase().replace(/[^A-Z0-9]/g, "");

            if (raw.length === 0) return;

            const firstChar = raw.charAt(0);

            if (isNaN(firstChar)) {

                raw = raw.substring(0, 6);

                let formatted = raw;
                if (raw.length > 3) {
                    formatted = raw.slice(0, 3) + "-" + raw.slice(3);
                }

                placaInput.value = formatted;
                placaInput.maxLength = 7;
                placaHelp.innerText = "Formato detectado: ABC-123";

            } else {

                raw = raw.replace(/[^0-9]/g, "").substring(0, 6);

                placaInput.value = raw;
                placaInput.maxLength = 6;
                placaHelp.innerText = "Formato detectado: 123456";
            }
        });


        const colorPicker = document.getElementById("colorPicker");
        const colorHex = document.getElementById("colorHex");
        const colorPreview = document.getElementById("colorPreview");

        function hexToHSL(hex) {

            let r = parseInt(hex.substring(1,3),16)/255;
            let g = parseInt(hex.substring(3,5),16)/255;
            let b = parseInt(hex.substring(5,7),16)/255;

            let max=Math.max(r,g,b),min=Math.min(r,g,b);
            let h,s,l=(max+min)/2;

            if(max===min){h=s=0;}
            else{

                let d=max-min;
                s=l>0.5?d/(2-max-min):d/(max+min);

                switch(max){
                    case r:h=(g-b)/d+(g<b?6:0);break;
                    case g:h=(b-r)/d+2;break;
                    case b:h=(r-g)/d+4;break;
                }

                h*=60;
            }

            return {h,s,l};
        }

        function getColorName(hex){

            const {h,s,l}=hexToHSL(hex);

            if(l<0.15) return "Negro";
            if(l>0.85) return "Blanco";
            if(s<0.2) return "Gris";

            if(h<15||h>=345) return "Rojo";
            if(h<45) return "Naranja";
            if(h<65) return "Amarillo";
            if(h<170) return "Verde";
            if(h<200) return "Cian";
            if(h<255) return "Azul";
            if(h<290) return "Morado";
            if(h<345) return "Rosado";

            return "Color";
        }

        colorPicker.addEventListener('input',()=>{

            const hex=colorPicker.value;
            const colorName=getColorName(hex);

            colorHex.value=`${hex.toUpperCase()} - ${colorName}`;
            colorPreview.style.backgroundColor=hex;

        });

    </script>
}