@model IEnumerable<AParCarWeb.Models.Pago>

@{
    ViewData["Title"] = "Ingresos";
}

<div class="container mt-4">

    <h2 class="mb-4">@ViewData["Title"]</h2>

    <!-- FILTRO DE FECHAS -->
    <form method="get" class="row g-3 mb-4">
        <div class="col-auto">
            <label for="desde" class="form-label">Desde</label>
            <input type="date" name="desde" id="desde" value="@ViewBag.Desde" class="form-control" />
        </div>
        <div class="col-auto">
            <label for="hasta" class="form-label">Hasta</label>
            <input type="date" name="hasta" id="hasta" value="@ViewBag.Hasta" class="form-control" />
        </div>
        <div class="col-auto align-self-end">
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
    </form>

    <!-- RESUMEN -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-bg-primary h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Total Ingresos</h5>
                    <p class="card-text fs-4 fw-bold">₡@ViewBag.Total</p>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLA DE INGRESOS -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha</th>
                        <th>Vehículo</th>
                        <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.FechaPago.ToString("yyyy-MM-dd")</td>
                            <td>@p.Ticket!.Vehiculo!.Placa</td>
                            <td>₡@p.Monto</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- BOTONES DE EXPORTACIÓN -->
    <div class="mt-3 d-flex gap-2">
        <a class="btn btn-danger"
           asp-action="ExportarIngresosPDF"
           asp-route-desde="@ViewBag.Desde"
           asp-route-hasta="@ViewBag.Hasta">
            Exportar PDF
        </a>
        <a class="btn btn-success"
           asp-action="ExportarIngresosExcel"
           asp-route-desde="@ViewBag.Desde"
           asp-route-hasta="@ViewBag.Hasta">
            Exportar Excel
        </a>
    </div>
</div>