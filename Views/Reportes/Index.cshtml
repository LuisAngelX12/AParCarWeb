@{
    ViewData["Title"] = "Dashboard de Reportes";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Clientes</h5>
                <p class="card-text">@ViewBag.TotalClientes</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Vehículos</h5>
                <p class="card-text">@ViewBag.TotalVehiculos</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Espacios Disponibles</h5>
                <p class="card-text">@ViewBag.EspaciosDisponibles</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Ingresos Hoy</h5>
                <p class="card-text">₡@ViewBag.IngresosHoy</p>
            </div>
        </div>
    </div>
</div>

<p>Vehículos dentro del parqueo: <strong>@ViewBag.VehiculosDentro</strong></p>