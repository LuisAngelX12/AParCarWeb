@model AParCarWeb.Models.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div style="height:200px;"></div>

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="bi bi-person-vcard"></i> Detalles del Cliente
            </h4>

            <span class="badge bg-light text-dark">
                ID: @Model.ClienteId
            </span>
        </div>

        <div class="card-body">

            <div class="row g-4">

                <div class="col-md-6">
                    <label class="form-label text-muted">
                        <i class="bi bi-person"></i> Nombre
                    </label>
                    <div class="fw-semibold fs-5">
                        @Model.Nombre
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted">
                        <i class="bi bi-credit-card"></i> Identificación
                    </label>
                    <div class="fw-semibold">
                        @Model.Identificacion
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted">
                        <i class="bi bi-people"></i> Tipo de Cliente
                    </label>
                    <div>
                        <span class="badge bg-info text-dark">
                            @Model.TipoCliente
                        </span>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted">
                        <i class="bi bi-telephone"></i> Teléfono
                    </label>
                    <div class="fw-semibold">
                        @Model.Telefono
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted">
                        <i class="bi bi-envelope"></i> Email
                    </label>
                    <div class="fw-semibold">
                        @Model.Email
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted">
                        <i class="bi bi-person-badge"></i> Usuario Identity
                    </label>
                    <div class="fw-semibold text-break">
                        @Model.Usuario?.IdentityUserId
                    </div>
                </div>

            </div>

        </div>

        <div class="card-footer d-flex justify-content-between">

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Volver
            </a>

            <a href="@Url.Action("Edit", "Usuarios", new { id = Model.ClienteId })" class="btn btn-primary">
                <i class="bi bi-pencil-square"></i> Editar
            </a>

        </div>

    </div>

</div>