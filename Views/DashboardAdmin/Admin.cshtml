@{
    ViewData["Title"] = "Dashboard Administrador";
}

<div style="height:30px;"></div>

<div class="container-fluid">

    <h1 class="mb-4">
        <i class="bi bi-speedometer2"></i>
        Panel de Administración
    </h1>

    <!-- ===============================
        RESUMEN GENERAL
    ================================ -->

    <div class="row g-4">

        <!-- Clientes -->
        <div class="col-md-3">
            <div class="card shadow-sm border-start border-primary border-4 h-100">
                <div class="card-body text-center">

                    <i class="bi bi-people fs-1 text-primary"></i>

                    <h6 class="text-muted mt-2">Clientes</h6>

                    <h2>@ViewBag.TotalClientes</h2>

                    <a asp-controller="Clientes"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-primary mt-2">

                        <i class="bi bi-gear"></i>
                        Gestionar
                    </a>

                </div>
            </div>
        </div>


        <!-- Vehículos -->
        <div class="col-md-3">
            <div class="card shadow-sm border-start border-success border-4 h-100">
                <div class="card-body text-center">

                    <i class="bi bi-car-front fs-1 text-success"></i>

                    <h6 class="text-muted mt-2">Vehículos</h6>

                    <h2>@ViewBag.TotalVehiculos</h2>

                    <a asp-controller="Vehiculos"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-success mt-2">

                        <i class="bi bi-gear"></i>
                        Gestionar
                    </a>

                </div>
            </div>
        </div>


        <!-- Espacios -->
        <div class="col-md-3">
            <div class="card shadow-sm border-start border-warning border-4 h-100">
                <div class="card-body text-center">

                    <i class="bi bi-grid-3x3-gap fs-1 text-warning"></i>

                    <h6 class="text-muted mt-2">Espacios Disponibles</h6>

                    <h2>@ViewBag.EspaciosDisponibles</h2>

                    <a asp-controller="Espacios"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-warning mt-2">

                        <i class="bi bi-eye"></i>
                        Ver Espacios
                    </a>

                </div>
            </div>
        </div>


        <!-- Ingresos -->
        <div class="col-md-3">
            <div class="card shadow-sm border-start border-info border-4 h-100">
                <div class="card-body text-center">

                    <i class="bi bi-cash-coin fs-1 text-info"></i>

                    <h6 class="text-muted mt-2">Ingresos Hoy</h6>

                    <h2>₡@ViewBag.IngresosHoy</h2>

                    <a asp-controller="Reportes"
                       asp-action="Ingresos"
                       class="btn btn-sm btn-outline-info mt-2">

                        <i class="bi bi-bar-chart"></i>
                        Ver Reporte
                    </a>

                </div>
            </div>
        </div>

        <!-- Vehículos dentro -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">

                    <i class="bi bi-car-front-fill fs-1"></i>

                    <h5 class="mt-3">Vehículos Actualmente Dentro</h5>

                    <h1>@ViewBag.VehiculosDentro</h1>

                    <a asp-controller="Tickets"
                       asp-action="Index"
                       class="btn btn-outline-secondary btn-sm mt-2">
                        Ver Tickets Activos
                    </a>

                </div>
            </div>
        </div>


        <!-- Ocupación -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">

                    <i class="bi bi-pie-chart fs-1"></i>

                    <h5 class="mt-3">Ocupación del Parqueo</h5>

                    <h1>@ViewBag.PorcentajeOcupacion %</h1>

                    <a asp-controller="Reportes"
                       asp-action="Ocupacion"
                       class="btn btn-outline-secondary btn-sm mt-2">

                        Ver Detalle
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>

<hr class="my-5" />

<h3>
    <i class="bi bi-bell"></i>
    Notificaciones del Sistema
</h3>

@if (ViewBag.NotificacionesNoLeidas != null && ViewBag.NotificacionesNoLeidas.Count > 0)
{
    <div class="card shadow-sm mt-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Notificación</th>
                        <th>Mensaje</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in ViewBag.NotificacionesNoLeidas)
                    {
                        <tr>
                            <td>
                                <i class="bi bi-exclamation-circle text-warning fs-4"></i>
                            </td>
                            <td>
                                @n.Mensaje
                            </td>
                            <td>
                                <i class="bi bi-clock"></i>
                                @n.Fecha.ToCR12H()
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-success mt-3">
        <i class="bi bi-check-circle"></i>
        No hay notificaciones pendientes.
    </div>
}

<hr class="my-5" />

<h3>
    <i class="bi bi-bar-chart-line"></i>
    Últimos Reportes Generados
</h3>

@if (ViewBag.ReportesRecientes != null && ViewBag.ReportesRecientes.Count > 0)
{
    <div class="card shadow-sm mt-3">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Reporte</th>
                        <th>Generado por</th>
                        <th>Fecha</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var r in ViewBag.ReportesRecientes)
                    {
                        <tr>

                            <td>
                                <i class="bi bi-file-earmark-text text-primary"></i>
                                @r.TipoReporte
                            </td>

                            <td>
                                <i class="bi bi-person"></i>
                                @r.GeneradoPor
                            </td>

                            <td>
                                <i class="bi bi-clock"></i>
                                @r.FechaGeneracion.ToCR12H()
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
}
else
{
    <div class="alert alert-warning mt-3">
        <i class="bi bi-exclamation-triangle"></i>
        No se han generado reportes recientemente.
    </div>
}

<div style="height:30px;"></div>