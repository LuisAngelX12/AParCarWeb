{
  "ConnectionStrings": {
    "DefaultConnection": "DATABASE_URL"
  },
  "PayPal": {
    "ClientId": "PAYPAL_CLIENT_ID",
    "Secret": "PAYPAL_SECRET"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "EmailSettings": {
    "From": "EMAIL_FROM",
    "SmtpServer": "EMAIL_SMTP_SERVER",
    "Port": "EMAIL_PORT",
    "Username": "EMAIL_USERNAME",
    "Password": "EMAIL_PASSWORD"
  }
}