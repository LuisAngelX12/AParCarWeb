@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Recuperar contraseña";
}

<body class="identity-bg identity-animate">
    <div class="page-wrapper identity-animate">

        <div class="container d-flex align-items-center justify-content-center min-vh-100">
            <div class="row w-100 justify-content-center">
                <div class="col-12 col-sm-11 col-md-10 col-lg-9 col-xl-8">

                    <div class="card identity-card border-0 overflow-hidden">
                        <div class="row g-0">

                            <!-- LEFT / BRAND PANEL -->
                            <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center identity-brand">
                                <div class="p-5 text-center text-white">
                                    <h2 class="fw-bold mb-3">AParCar Web</h2>
                                    <p class="opacity-75 mb-4">
                                        Te ayudamos a recuperar el acceso
                                        de forma rápida y segura.
                                    </p>
                                </div>
                            </div>

                            <!-- RIGHT / FORM PANEL -->
                            <div class="col-md-6 p-5">
                                <h3 class="fw-bold mb-1">
                                    ¿Olvidaste tu contraseña?
                                    <i class="bi bi-lock"></i>
                                </h3>
                                <p class="text-muted mb-4">
                                    Ingresa tu correo y te enviaremos un enlace
                                </p>

                                <form method="post" novalidate>

                                    <div asp-validation-summary="ModelOnly"
                                         class="alert alert-danger py-2 small"
                                         role="alert"></div>

                                    <div class="form-floating mb-4">
                                        <input asp-for="Input.Email"
                                               class="form-control"
                                               placeholder=""
                                               autocomplete="username" />
                                        <label asp-for="Input.Email">Correo electrónico</label>
                                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                    </div>

                                    <button type="submit"
                                            class="btn btn-dark w-100 py-2 fw-semibold">
                                        Enviar enlace
                                    </button>

                                    <div class="text-center mt-4 small">
                                        <a asp-page="./Login"
                                               class="fw-semibold text-decoration-none identity-link">
                                            Volver a iniciar sesión
                                        </a>
                                    </div>

                                </form>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

</body>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}