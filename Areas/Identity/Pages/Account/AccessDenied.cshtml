@page
@model AccessDeniedModel

@{
    Layout = null;
    ViewData["Title"] = "Acceso denegado";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <style>
        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #1e1e2f, #2a2a40);
            color: #fff;

            /* ❌ Evitar selección */
            user-select: none;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
        }

        .container {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #2f2f46;
            padding: 3rem;
            border-radius: 12px;
            text-align: center;
            max-width: 420px;
            box-shadow: 0 20px 40px rgba(0,0,0,.4);
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            color: #ff6b6b;
        }

        p {
            font-size: 1.1rem;
            opacity: .9;
        }

        a {
            display: inline-block;
            margin-top: 2rem;
            padding: .75rem 1.5rem;
            background: #ff6b6b;
            color: #fff;
            text-decoration: none;
            border-radius: 8px;
            transition: background .3s ease;
        }

        a:hover {
            background: #ff4c4c;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h1>Acceso denegado</h1>
            <p>No tienes permisos para acceder a este recurso.</p>

            <a asp-area="Identity" asp-page="/Account/Login">
                Volver al inicio</a>
        </div>
    </div>
</body>
</html>