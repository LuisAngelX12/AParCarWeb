@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configurar app de autenticación";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>

<div>
    <p>Para usar una aplicación de autenticación, sigue estos pasos:</p>

    <ol class="list">
        <li>
            <p>
                Descarga una app de autenticación en dos factores como Microsoft Authenticator para
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a> y
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a>, o Google Authenticator para
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=es">Android</a> y
                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
            </p>
        </li>

        <li>
            <p>
                Escanea el código QR o introduce esta clave
                <kbd>@Model.SharedKey</kbd> en tu app de autenticación.
                Los espacios y mayúsculas no afectan.
            </p>

            <div class="alert alert-info">
                Aprende cómo <a href="https://go.microsoft.com/fwlink/?Linkid=852423">habilitar la generación de códigos QR</a>.
            </div>

            <div id="qrCode"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>

        <li>
            <p>
                Una vez que escanees el código QR o ingreses la clave, la app generará un código único.
                Ingresa ese código en el siguiente campo de confirmación.
            </p>

            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" />
                            <label asp-for="Input.Code" class="control-label form-label">Código de verificación</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-lg btn-primary">
                            Verificar
                        </button>

                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}