@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div style="height:30px;"></div>

<h1>Administrar tu cuenta</h1>
<div>
    <h2>Cambiar la configuración de tu cuenta</h2>
    <hr />

    <div class="row g-4">
        <!-- BARRA LATERAL: NO TOCAR -->
        <div class="col-md-3">
            <partial name="_ManageNav" />
        </div>

        <!-- CONTENIDO: lo envolvemos en container → card -->
        <div class="col-md-9">
            <div class="container py-4 p-0">
                <!-- opcional p-0 para que no duplique los paddings -->
                <div class="card identity-card p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}